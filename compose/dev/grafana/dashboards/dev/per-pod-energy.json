  "description": "Per-pod energy dashboard for Kepler v0.11.x (legacy layout adapted)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 11,
      "panels": [],
      "title": "Carbon Emissions",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "CO2 pounds/kWh/day using US EIA coefficients. Based on package-zone energy over 24h.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 1 },
      "id": 12,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "9.1.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "( sum( increase( kepler_pod_cpu_joules_total{zone=\"package\", pod_namespace=~\"$namespace\", pod_name=~\"$pod\"}[24h:1m] ) ) * $watt_per_second_to_kWh ) * $coal",
          "legendFormat": "CO2 Coal",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "( sum( increase( kepler_pod_cpu_joules_total{zone=\"package\", pod_namespace=~\"$namespace\", pod_name=~\"$pod\"}[24h:1m] ) ) * $watt_per_second_to_kWh ) * $petroleum",
          "legendFormat": "CO2 Petroleum",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "( sum( increase( kepler_pod_cpu_joules_total{zone=\"package\", pod_namespace=~\"$namespace\", pod_name=~\"$pod\"}[24h:1m] ) ) * $watt_per_second_to_kWh ) * $natural_gas",
          "legendFormat": "CO2 Natural Gas",
          "range": true,
          "refId": "C"
        }
      ],
      "title": "Carbon Footprint (lb / kWh / day) — Namespace: $namespace",
      "transparent": true,
      "type": "gauge"
    },
    {
      "collapsed": false,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 8,
      "panels": [],
      "title": "Power Consumption",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "watt",
            "drawStyle": "bars",
            "fillOpacity": 44,
            "gradientMode": "opacity",
            "lineWidth": 0,
            "pointSize": 5,
            "showPoints": "always",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 80 } ] }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*package.*" }, "properties": [ { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } } ] },
          { "matcher": { "id": "byRegexp", "options": ".*core.*" }, "properties": [ { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } } ] },
          { "matcher": { "id": "byRegexp", "options": ".*uncore.*" }, "properties": [ { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } } ] },
          { "matcher": { "id": "byRegexp", "options": ".*dram.*" }, "properties": [ { "id": "color", "value": { "fixedColor": "semi-dark-green", "mode": "fixed" } } ] }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "id": 16,
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "right", "showLegend": true, "sortBy": "Mean", "sortDesc": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum by (pod_name, pod_namespace, zone) (irate(kepler_pod_cpu_joules_total{pod_namespace=~\"$namespace\", pod_name=~\"$pod\"}[1m]))",
          "legendFormat": "{{pod_name}} / {{pod_namespace}} / {{zone}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Pod Power Consumption (W) by Zone — Namespace: $namespace",
      "type": "timeseries"
    },
