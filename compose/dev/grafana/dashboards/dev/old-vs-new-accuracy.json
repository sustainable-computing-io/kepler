          "expr": "sum(kepler_node_cpu_watts{node_name=~\"$nodename\"}) by (node_name)",
          "hide": false,
          "legendFormat": "new: node_cpu_watts",
          "range": true,
          "refId": "NEW_NODE"
        }
      ],
      "title": "Node CPU power - old_kepler_node_package_joules vs kepler_node_cpu_joules  +  IPMI",
      "type": "timeseries"
    },
