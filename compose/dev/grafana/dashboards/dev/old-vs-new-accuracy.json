  "description": "Kepler accuracy: old_ (RAPL package joules) vs new (RAPL package joules, native) vs IPMI ground truth. Both Kepler versions measure CPU package only. IPMI is full-node reference.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "Node-level CPU energy - old vs new vs IPMI reference",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Node-level comparison. old_kepler_node_package_joules_total and kepler_node_cpu_joules_total both read the RAPL Package domain (entire CPU socket). Converting the joules counter with rate() gives instantaneous watts. IPMI is the full-node power draw from the BMC - it includes DRAM, fans, NICs, and PSU losses on top of CPU, so Kepler values are expected to be 40-70% of IPMI.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "line",
            "fillOpacity": 7,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "watt"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "IPMI: node total (W)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#37872D",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 2
              },
              {
                "id": "custom.fillOpacity",
                "value": 4
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    8,
                    4
                  ],
                  "fill": "dash"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "old: rate(node_pkg_joules) W"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#E05C30",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "new: rate(node_cpu_joules) W"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#7B61FF",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max",
            "min"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "avg(ipmi_node_power_watts{node_name=~\"$nodename\"}) by (node_name)",
          "legendFormat": "IPMI: node total (W)",
          "range": true,
          "refId": "IPMI"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum(rate(old_kepler_node_package_joules_total{instance=~\"$nodename\"}[$__rate_interval])) by (instance)",
          "legendFormat": "old: rate(node_pkg_joules) W",
          "range": true,
          "refId": "OLD_NODE"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum(rate(old_kepler_node_platform_joules_total{instance=~\"$nodename\"}[$__rate_interval])) by (node_name)",
          "hide": false,
          "interval": "",
          "legendFormat": "old: rate(full_node_joules) W",
          "range": true,
          "refId": "OLD_KEPLER"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
